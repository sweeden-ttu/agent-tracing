{
  "variant": "baseline_column_transformer",
  "approach": "ColumnTransformer + LightGBM baseline",
  "phases": [
    "01_data_analysis",
    "02_statistical_framework",
    "03_feature_engineering",
    "04_model_training",
    "05_evaluation",
    "06_submission"
  ],
  "agents": {
    "data": "eda_profiler",
    "plan": "experiment-design-architect",
    "model": "model_trainer",
    "eval": "oof_evaluator",
    "submit": "kaggle_submitter",
    "type3_consumer": "schema-sentinel"
  },
  "metric": "rmse",
  "smre": "mean_rmse_plus_std_across_folds",
  "ablations": [
    {
      "id": "target_log1p",
      "factor": "target_transform",
      "levels": [
        "none",
        "log1p"
      ]
    },
    {
      "id": "numeric_scaler",
      "factor": "preprocessor",
      "levels": [
        "standard",
        "robust"
      ]
    },
    {
      "id": "rolling_window",
      "factor": "feature_window",
      "levels": [
        "32",
        "64",
        "128"
      ]
    }
  ],
  "experiment_descriptor": "experiment_descriptor.json",
  "base_papers": [
    "ke2017_lightgbm",
    "pedregosa2011_sklearn"
  ],
  "base_paper_role": "dual: model (LightGBM) + preprocessing (ColumnTransformer)",
  "agent_implementation": "traces/preprocessing/baseline_column_transformer/trace_language.csv",
  "experiment_design_architect": {
    "agent": "experiment-design-architect",
    "tokens": [
      "write_mle_plan_json",
      "define_statistical_framework",
      "design_ablation_factorial_grid",
      "configure_variant_ablation_flags",
      "plan_episodic_training_schedule",
      "define_episode_boundaries_by_well_or_fold",
      "record_ablation_plan"
    ]
  }
}