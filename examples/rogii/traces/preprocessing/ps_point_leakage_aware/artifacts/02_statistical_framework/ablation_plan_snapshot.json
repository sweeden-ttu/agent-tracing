{
  "variant": "ps_point_leakage_aware",
  "approach": "PS-point detection + post-PS RMSE mask",
  "ablation_factors": [
    {
      "id": "ps_mask",
      "factor": "eval_mask",
      "levels": [
        "full_well",
        "post_ps_only"
      ]
    },
    {
      "id": "ps_detector",
      "factor": "ps_detection",
      "levels": [
        "auto",
        "manual_offset"
      ]
    },
    {
      "id": "leakage_audit",
      "factor": "tvt_input_audit",
      "levels": [
        "strict",
        "lenient"
      ]
    }
  ],
  "factorial_grid_size": 8,
  "factorial_grid_sample": [
    {
      "ps_mask": "full_well",
      "ps_detector": "auto",
      "leakage_audit": "strict"
    },
    {
      "ps_mask": "full_well",
      "ps_detector": "auto",
      "leakage_audit": "lenient"
    },
    {
      "ps_mask": "full_well",
      "ps_detector": "manual_offset",
      "leakage_audit": "strict"
    },
    {
      "ps_mask": "full_well",
      "ps_detector": "manual_offset",
      "leakage_audit": "lenient"
    },
    {
      "ps_mask": "post_ps_only",
      "ps_detector": "auto",
      "leakage_audit": "strict"
    },
    {
      "ps_mask": "post_ps_only",
      "ps_detector": "auto",
      "leakage_audit": "lenient"
    },
    {
      "ps_mask": "post_ps_only",
      "ps_detector": "manual_offset",
      "leakage_audit": "strict"
    },
    {
      "ps_mask": "post_ps_only",
      "ps_detector": "manual_offset",
      "leakage_audit": "lenient"
    }
  ],
  "primary_metric": "rmse_post_ps",
  "smre": "mean_rmse_plus_std_across_folds",
  "episodic_training": true,
  "slurm_single_job_per_branch": true
}
