{
  "variant": "ps_point_leakage_aware",
  "approach": "PS-point detection + post-PS RMSE mask",
  "phases": [
    "01_data_analysis",
    "02_statistical_framework",
    "03_feature_engineering",
    "04_model_training",
    "05_evaluation",
    "06_submission"
  ],
  "agents": {
    "data": "eda_profiler",
    "plan": "experiment-design-architect",
    "model": "model_trainer",
    "eval": "oof_evaluator",
    "submit": "kaggle_submitter",
    "type3_consumer": "schema-sentinel"
  },
  "metric": "rmse",
  "smre": "mean_rmse_plus_std_across_folds",
  "ablations": [
    {
      "id": "ps_mask",
      "factor": "eval_mask",
      "levels": [
        "full_well",
        "post_ps_only"
      ]
    },
    {
      "id": "ps_detector",
      "factor": "ps_detection",
      "levels": [
        "auto",
        "manual_offset"
      ]
    },
    {
      "id": "leakage_audit",
      "factor": "tvt_input_audit",
      "levels": [
        "strict",
        "lenient"
      ]
    }
  ],
  "experiment_descriptor": "experiment_descriptor.json",
  "base_paper_role": "primary_experiment_descriptor",
  "agent_implementation": "traces/preprocessing/ps_point_leakage_aware/trace_language.csv",
  "experiment_design_architect": {
    "agent": "experiment-design-architect",
    "tokens": [
      "write_mle_plan_json",
      "define_statistical_framework",
      "design_ablation_factorial_grid",
      "configure_variant_ablation_flags",
      "plan_episodic_training_schedule",
      "define_episode_boundaries_by_well_or_fold",
      "record_ablation_plan"
    ]
  }
}